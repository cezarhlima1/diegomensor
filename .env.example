# Copie este arquivo para .env.local e preencha com os valores reais.

# --- Supabase (Dashboard > Settings > API) ---

# URL do projeto Supabase (pública — vai para o bundle do cliente).
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (pública) — toda leitura com ela passa pelo RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service role — SECRETA, ignora RLS. Somente server-side
# (sem prefixo NEXT_PUBLIC_). Nunca commitar o valor real.
SUPABASE_SERVICE_ROLE_KEY=

# --- Leads ---

# URL do Web App do Google Apps Script (Implantar > App da Web),
# usada por /api/lead para gravar leads na planilha.
SHEETS_WEBHOOK_URL=

# URL do Web App do Apps Script vinculado à planilha da pesquisa DESTRAVE.
# O código para publicar está em scripts/pesquisa-destrave.gs.
DESTRAVE_SHEETS_WEBHOOK_URL=
